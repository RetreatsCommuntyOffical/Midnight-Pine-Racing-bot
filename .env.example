BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
HOME_GUILD_ID=your_guild_id_here
MONGO_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/midnightpineracing?retryWrites=true&w=majority
ALLOW_STARTUP_WITHOUT_DB=true
OWNER_ID=your_discord_user_id
LEADERBOARDS_BANNER_URL=
SOLO_BOARD_BANNER_URL=
STREET_BOARD_BANNER_URL=
CIRCUIT_BOARD_BANNER_URL=
TEAMS_BANNER_URL=
WELCOME_BANNER_URL=
ROLE_SELECTION_BANNER_URL=
SUPPORT_HUB_BANNER_URL=
TEAM_HUB_BANNER_URL=
ASSET_UPLOAD_CHANNEL_ID=
BOT_LOGS_CHANNEL_ID=
TEAM_HUB_CHANNEL_ID=
SUPPORT_HUB_CHANNEL_ID=
WELCOME_CHANNEL_ID=
ENABLE_GUILD_MEMBERS_INTENT=false
INTEGRATION_PORT=8787
INTEGRATION_WEBHOOK_SECRET=replace_with_strong_secret
LINUX_SYNC_ENABLED=false
LINUX_SYNC_URL=https://your-linux-server.example.com/api/discord/embeds
LINUX_SYNC_TOKEN=replace_with_linux_api_token
LINUX_SYNC_INTERVAL_SEC=180
LINUX_SYNC_TIMEOUT_MS=10000
EMBED_SYNC_ENABLED=true
EMBED_SYNC_SOURCE=local
EMBED_SYNC_FILE=./deploy/linux-embed-sync/embeds.json
EMBED_SYNC_INTERVAL_SEC=180
EMBED_SYNC_TIMEOUT_MS=10000

# Comma-separated channel IDs exempt from embed merge (e.g. log/dev channels)
EMBED_WHITELIST_CHANNELS=

# ── Music System ──────────────────────────────────────────────────────────────
# Channel where now-playing announcements are posted
MUSIC_ANNOUNCE_CHANNEL_ID=
# FiveM server pushes music events here (same port as integration webhook)
# In server.cfg: set midnight_music_webhook_url "http://<bot-ip>:8787/ingest/music"
# In server.cfg: set midnight_music_webhook_secret "your-secret-here"
